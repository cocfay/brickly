<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Si la ruta comienza con api/, redirigir al archivo PHP correspondiente
  RewriteRule ^api/upload-logo$ api/upload-logo.php [L,QSA]

  # No redirigir archivos o directorios existentes
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Todo lo demás va al index.html
  RewriteRule ^ index.html [L]
</IfModule>

Options -MultiViews

# Compresión Brotli (mejor que gzip, ~20% más compacto)
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
  BrotliCompressionQuality 11
</IfModule>

# Fallback a gzip si Brotli no está disponible
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# Cache de archivos estáticos (1 año para archivos con hash, 1 semana para el resto)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresDefault "access plus 1 week"
</IfModule>

# Cache-Control headers adicionales
<IfModule mod_headers.c>
  # Assets con hash (Vite genera nombres únicos) - cachear por 1 año
  <FilesMatch "[-.][A-Za-z0-9_-]{8,}\.(?:js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # Imágenes - cachear por 1 año
  <FilesMatch "\.(webp|avif|png|jpg|jpeg|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # Fuentes - cachear por 1 año
  <FilesMatch "\.(woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # HTML - no cachear (siempre obtener la última versión)
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
